<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:padding="12dp">

    <!-- RAM -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal">
        <TextView
            android:id="@+id/widget_ram_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAM"
            android:textColor="#6B8880"
            android:textSize="9sp"
            android:letterSpacing="0.1" />
        <TextView
            android:id="@+id/widget_ram_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#00E87A"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divisor -->
    <View
        android:layout_width="1dp"
        android:layout_height="32dp"
        android:background="#243028" />

    <!-- Bateria -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal">
        <TextView
            android:id="@+id/widget_bat_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BAT"
            android:textColor="#6B8880"
            android:textSize="9sp"
            android:letterSpacing="0.1" />
        <TextView
            android:id="@+id/widget_bat_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#00E87A"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divisor -->
    <View
        android:layout_width="1dp"
        android:layout_height="32dp"
        android:background="#243028" />

    <!-- Temperatura -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal">
        <TextView
            android:id="@+id/widget_temp_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TEMP"
            android:textColor="#6B8880"
            android:textSize="9sp"
            android:letterSpacing="0.1" />
        <TextView
            android:id="@+id/widget_temp_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--°C"
            android:textColor="#00E87A"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
